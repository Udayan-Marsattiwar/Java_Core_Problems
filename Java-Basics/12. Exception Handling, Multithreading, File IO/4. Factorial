import java.util.Scanner;
import java.math.BigInteger;
class Main {
    public static void main(String[] args) {
        BigInteger f = new BigInteger("1");
        Scanner sc = new Scanner(System.in);
        int i;
        int n = sc.nextInt();
        BigInteger b = null;
        for(i=1; i<n; i++){
            b = BigInteger.valueOf(i);
            f = f.multiply(b);
        }
        System.out.println(f);
    }
}
